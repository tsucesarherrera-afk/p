<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panel Principal - Sistema de Rehabilitación</title>
    <link rel="stylesheet" href="css/styles.css">
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <script src="https://cdn.sheetjs.com/xlsx-0.20.0/package/dist/xlsx.full.min.js"></script>
</head>
<body>
    <!-- Barra de Navegación Principal -->
    <nav class="main-navbar">
        <div class="nav-brand">
            <span class="logo-small">❤️+</span>
            <span class="brand-text">Control de Rehabilitación</span>
        </div>
        
        <ul class="nav-menu">
            <li class="nav-item dropdown">
                <a href="#" class="nav-link" onclick="toggleMenu('menuRegistro')">
                    📋 Registro ▼
                </a>
                <ul id="menuRegistro" class="dropdown-menu">
                    <li><a href="#" onclick="abrirModulo('medicos')">👨‍⚕️ Médico</a></li>
                    <li><a href="#" onclick="abrirModulo('estudiantes')">🎓 Estudiante Fisioterapeuta</a></li>
                    <li><a href="#" onclick="abrirModulo('pacientes')">🧑 Paciente</a></li>
                    <li><a href="#" onclick="abrirModulo('fisioterapeutas')">🏃 Fisioterapeuta</a></li>
                    <li><a href="#" onclick="abrirModulo('especialidades')">📚 Especialidad</a></li>
                    <li><a href="#" onclick="abrirModulo('terapias')">💆 Terapia</a></li>
                    <li><a href="#" onclick="abrirModulo('estados')">📍 Estado</a></li>
                </ul>
            </li>
            
            <li class="nav-item dropdown">
                <a href="#" class="nav-link" onclick="toggleMenu('menuProcesos')">
                    ⚙️ Procesos ▼
                </a>
                <ul id="menuProcesos" class="dropdown-menu">
                    <li><a href="#" onclick="abrirModulo('citas')">📅 Control de Cita</a></li>
                    <li><a href="#" onclick="abrirModulo('consultas')">📝 Registro de Consulta</a></li>
                    <li><a href="#" onclick="abrirModulo('rehabilitacion')">🏥 Control de Rehabilitación</a></li>
                </ul>
            </li>
            
            <li class="nav-item dropdown">
                <a href="#" class="nav-link" onclick="toggleMenu('menuReportes')">
                    📊 Reportes ▼
                </a>
                <ul id="menuReportes" class="dropdown-menu">
                    <li><a href="#" onclick="abrirModulo('reportePacientes')">👥 Pacientes</a></li>
                    <li><a href="#" onclick="abrirModulo('reporteCitas')">📅 Citas</a></li>
                    <li><a href="#" onclick="abrirModulo('reporteTerapias')">💆 Terapias</a></li>
                    <li><a href="#" onclick="abrirModulo('reporteHistorias')">📋 Historias Clínicas</a></li>
                </ul>
            </li>
            
            <li class="nav-item dropdown" id="menuSeguridad" style="display:none;">
                <a href="#" class="nav-link" onclick="toggleMenu('menuSeguridadSub')">
                    🔒 Seguridad ▼
                </a>
                <ul id="menuSeguridadSub" class="dropdown-menu">
                    <li><a href="#" onclick="abrirModulo('logs')">📋 Logs de Auditoría</a></li>
                </ul>
            </li>
            
            <li class="nav-item dropdown" id="menuUsuarios" style="display:none;">
                <a href="#" class="nav-link" onclick="toggleMenu('menuUsuariosSub')">
                    👤 Usuarios ▼
                </a>
                <ul id="menuUsuariosSub" class="dropdown-menu">
                    <li><a href="#" onclick="abrirModulo('usuarios')">👥 Gestión de Usuarios</a></li>
                    <li><a href="#" onclick="abrirModulo('perfil')">⚙️ Mi Perfil</a></li>
                </ul>
            </li>
            
            <li class="nav-item">
                <a href="#" class="nav-link nav-logout" onclick="cerrarSesion()">
                    🚪 Salir
                </a>
            </li>
        </ul>
        
        <div class="user-info">
            <span id="userName">Cargando...</span>
            <span id="userRole" class="role-badge">Rol</span>
        </div>
    </nav>

    <!-- Contenido Principal -->
    <main class="main-content">
        <!-- Vista Dashboard -->
        <div id="vistaDashboard" class="vista-activa">
            <div class="welcome-section">
                <h1 class="main-title">SISTEMA PARA LA ATENCIÓN DE PACIENTES</h1>
                <div class="institution-logo">❤️+</div>
            </div>
            
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon">🧑</div>
                    <div class="stat-number" id="statPacientes">0</div>
                    <div class="stat-label">Pacientes Registrados</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">📅</div>
                    <div class="stat-number" id="statCitasHoy">0</div>
                    <div class="stat-label">Citas Hoy</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">💆</div>
                    <div class="stat-number" id="statTerapias">0</div>
                    <div class="stat-label">Terapias Realizadas</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">🏥</div>
                    <div class="stat-number" id="statRehabilitacion">0</div>
                    <div class="stat-label">En Rehabilitación</div>
                </div>
            </div>
            
            <div class="quick-actions">
                <h3>⚡ Accesos Rápidos</h3>
                <div class="action-buttons">
                    <button class="action-btn" onclick="abrirModulo('pacientes')">
                        <span>➕</span> Nuevo Paciente
                    </button>
                    <button class="action-btn" onclick="abrirModulo('citas')">
                        <span>📅</span> Nueva Cita
                    </button>
                    <button class="action-btn" onclick="abrirModulo('consultas')">
                        <span>📝</span> Nueva Consulta
                    </button>
                    <button class="action-btn" onclick="abrirModulo('rehabilitacion')">
                        <span>🏥</span> Nueva Rehabilitación
                    </button>
                </div>
            </div>
        </div>

        <!-- Contenedor dinámico para módulos -->
        <div id="contenedorModulos" class="contenedor-modulos" style="display:none;">
        </div>
    </main>

    <!-- Scripts -->
    <script src="js/supabase-client.js"></script>
    <script src="js/auth.js"></script>
    <script src="js/dashboard.js"></script>
    <script src="js/modules/pacientes.js"></script>
    <script src="js/modules/medicos.js"></script>
    <script src="js/modules/fisioterapeutas.js"></script>
    <script src="js/modules/estudiantes.js"></script>
    <script src="js/modules/catalogos.js"></script>
    <script src="js/modules/citas.js"></script>
    <script src="js/modules/consultas.js"></script>
    <script src="js/modules/rehabilitacion.js"></script>
    <script src="js/modules/usuarios.js"></script>
    <script src="js/modules/reportes.js"></script>
</body>
</html>
